{
  "name": "tease",
  "version": "0.1.0",
  "description": "Automated project showcase capture — screenshots, GIFs, and videos from web apps, desktop, and terminal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tease": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "screenshot",
    "capture",
    "gif",
    "video",
    "showcase",
    "readme",
    "playwright",
    "terminal",
    "desktop"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "cac": "^6.7.14",
    "cosmiconfig": "^9.0.0",
    "cosmiconfig-typescript-loader": "^6.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-pty": "^1.0.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.49.0",
    "screenshot-desktop": "^1.15.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.0",
    "serve": "^14.2.6",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
